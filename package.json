{
  "name": "jw-automation-tools",
  "version": "1.0.0",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.1",
    "ulid": "^2.3.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "axios": "^1.14.0",
    "fs-extra": "^11.3.4",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "yargs": "^18.0.0"
  },
  "scripts": {
    "install-tools": "npm install -g .",
    "install-skills": "npm run install-skills-core && npm run install-skills-personal",
    "install-skills-core": "gemini skills install src/skills/core/autonomous-researcher --consent && gemini skills install src/skills/core/interactive-web-explorer --consent && gemini skills install src/skills/core/coding-step-planner --consent && gemini skills install src/skills/core/skill-auditor --consent",
    "install-skills-personal": "gemini skills install src/skills/personal/jw-assistant-toolkit --consent",
    "test": "npx tsx tests/tools_integration.spec.ts"
  },
  "bin": {
    "kokoro-tts": "./src/tools/core/kokoro_tool.ts",
    "browser-engine": "./src/tools/core/browser_engine.ts",
    "autonomous-researcher": "./src/tools/core/autonomous-researcher/index.ts",
    "skill-auditor": "./src/tools/core/skill-auditor/index.ts",
    "home-assistant-mcp": "./src/tools/core/home-assistant-mcp/index.ts",
    "jw-scraper-daily": "./src/tools/personal/jw_scraper_daily_text_tool.ts",
    "jw-daily-orchestrator": "./src/tools/personal/jw_daily_orchestrator.ts",
    "wol-research": "./src/tools/personal/interactive_wol_research.ts"
  }
}
